# WLED API Proxy - Apache URL Rewriting
# This .htaccess is in the plugin's www directory

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /plugin/fpp-WLEDProxy/

    # Always route to wled_api.php, regardless of request
    # This ensures the PHP handler always gets called to determine the endpoint
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ wled_api.php?_path=/$0 [L,QSA,PT]
</IfModule>
