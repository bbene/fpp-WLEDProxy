{
    "repoName": "fpp-WLEDProxy",
    "name": "FPP WLED API Proxy",
    "author": "Ben Benesh",
    "description": "Exposes FPP as a WLED-compatible device. Allows any WLED app (Lightbow, WLED Wiz, Home Assistant, etc.) to discover and control FPP's overlay model effects as if FPP were a real WLED device.",
    "homeURL": "https://github.com/bbene/fpp-WLEDProxy",
    "srcURL": "https://github.com/bbene/fpp-WLEDProxy.git",
    "bugURL": "https://github.com/bbene/fpp-WLEDProxy/issues",
    "allowUpdates": 1,
    "versions": [
        {
            "minFPPVersion": "7.0",
            "maxFPPVersion": "7.99",
            "branch": "main",
            "sha": "",
            "dependencies": {
                "packages": [
                    "avahi-utils"
                ]
            }
        },
