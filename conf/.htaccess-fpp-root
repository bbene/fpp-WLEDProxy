# FPP WLED API Proxy - Root Level Rewrite Rules
# Routes WLED API requests to the plugin handler

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Don't rewrite if it's a real file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Only match /json or /win paths
    RewriteCond %{REQUEST_URI} ^/(json|win)

    # Rewrite to plugin handler, passing the original path as _path query param
    RewriteRule ^(.+)$ /plugin/fpp-WLEDProxy/wled_api.php?_path=/$1 [L,QSA,PT]
</IfModule>
