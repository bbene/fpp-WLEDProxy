# FPP WLED API Proxy - Root Level Rewrite Rules
# Routes WLED API requests to the plugin handler

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Don't rewrite if it's a real file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # WLED JSON API - route all /json/* requests to plugin handler
    # REQUEST_URI is preserved by Apache and will contain the original path
    RewriteRule ^json(/.*)?$ /plugin/fpp-WLEDProxy/wled_api.php [L,QSA]

    # WLED HTTP Request API - route all /win* requests to plugin handler
    RewriteRule ^win(/.*)?$ /plugin/fpp-WLEDProxy/wled_api.php [L,QSA]
</IfModule>
