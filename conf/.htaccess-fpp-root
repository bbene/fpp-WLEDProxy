# FPP WLED API Proxy - Root Level Rewrite Rules
# Routes WLED API requests to the plugin handler

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Don't rewrite if it's a real file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # WLED JSON API - route to plugin, preserving original path in WLED_PATH env var
    RewriteRule ^(json.*)$ /plugin/fpp-WLEDProxy/wled_api.php [E=WLED_PATH:/$1,L,QSA]

    # WLED HTTP Request API - route to plugin, preserving original path
    RewriteRule ^(win.*)$ /plugin/fpp-WLEDProxy/wled_api.php [E=WLED_PATH:/$1,L,QSA]
</IfModule>
