# FPP WLED API Proxy - Root Level Rewrite Rules
# Routes WLED API requests to the plugin handler

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Don't rewrite if it's a real file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # WLED JSON API - route to plugin, passing original path as _wled_path query parameter
    RewriteRule ^(json/.*)$ /plugin/fpp-WLEDProxy/wled_api.php?_wled_path=$1 [L,QSA]
    RewriteRule ^json$ /plugin/fpp-WLEDProxy/wled_api.php?_wled_path=json [L,QSA]

    # WLED HTTP Request API - route to plugin, passing original path as query parameter
    RewriteRule ^(win.*)$ /plugin/fpp-WLEDProxy/wled_api.php?_wled_path=$1 [L,QSA]
</IfModule>
